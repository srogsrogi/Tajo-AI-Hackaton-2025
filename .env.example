# 환경 변수 설정 예시
# 이 파일을 .env로 복사하고 실제 값으로 변경하세요

# OpenAI API 키 (필수)
# https://platform.openai.com/api-keys 에서 발급받으세요
OPENAI_API_KEY=sk-your-openai-api-key-here

# 서버 공개 도메인 (필수)
# Twilio가 접근할 수 있는 공개 URL이어야 합니다
PUBLIC_DOMAIN=https://your-domain.com

# 또는 EC2 공개 IP 사용 시:
# PUBLIC_DOMAIN=http://your-ec2-public-ip:5050

# 또는 ngrok 사용 시:
# PUBLIC_DOMAIN=https://your-ngrok-url.ngrok.io

# 포트 설정 (선택사항, 기본값: 5050)
PORT=5050

# 사용 방법:
# 1. 이 파일을 .env로 복사: cp .env.example .env
# 2. 실제 값으로 변경
# 3. 서버 실행: source venv/bin/activate && python main.py